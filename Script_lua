-- ESP (Jugadores)
CreateToggle("ESP Players", function(state)
    if state then
        task.spawn(function()
            while Toggles["ESP Players"] do
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        local role = GetRole(v)
                        local color = Color3.fromRGB(255, 255, 255) -- Inocente (Blanco)
                        if role == "Murderer" then color = Color3.fromRGB(255, 0, 0) end
                        if role == "Sheriff" then color = Color3.fromRGB(0, 0, 255) end
                        
                        if not v.Character:FindFirstChild("SilletESP") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "SilletESP"
                            highlight.Parent = v.Character
                            highlight.FillTransparency = 0.5
                            highlight.OutlineTransparency = 0
                            highlight.FillColor = color
                            highlight.OutlineColor = color
                        else
                            v.Character.SilletESP.FillColor = color
                            v.Character.SilletESP.OutlineColor = color
                        end
                    end
                end
                task.wait(1)
            end
        end)
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character and v.Character:FindFirstChild("SilletESP") then
                v.Character.SilletESP:Destroy()
            end
        end
    end
end)

