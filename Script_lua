        end)
    else
        local gunDrop = Workspace:FindFirstChild("GunDrop")
        if gunDrop and gunDrop:FindFirstChild("SilletGunESP") then
            gunDrop.SilletGunESP:Destroy()
        end
    end
end)

-- ESP (Monedas)
CreateToggle("ESP Coins", function(state)
    if state then
        task.spawn(function()
            while Toggles["ESP Coins"] do
                local map = Workspace:FindFirstChild("Normal")
                if map and map:FindFirstChild("CoinContainer") then
                    for _, coin in pairs(map.CoinContainer:GetChildren()) do
                        if not coin:FindFirstChild("SilletCoinESP") then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "SilletCoinESP"
                            highlight.Parent = coin
                            highlight.FillColor = Color3.fromRGB(0, 255, 0) -- Verde
                            highlight.FillTransparency = 0.6
                        end
                    end
                end
                task.wait(2)
            end
        end)
    else
        local map = Workspace:FindFirstChild("Normal")
        if map and map:FindFirstChild("CoinContainer") then
            for _, coin in pairs(map.CoinContainer:GetChildren()) do
                if coin:FindFirstChild("SilletCoinESP") then
                    coin.SilletCoinESP:Destroy()
                end
            end
        end
    end
end)

