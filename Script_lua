-- Fly
local bodyVelocity = nil
CreateToggle("Fly", function(state)
    local character = LocalPlayer.Character
    if state and character and character:FindFirstChild("HumanoidRootPart") then
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = character.HumanoidRootPart
        
        task.spawn(function()
            while Toggles["Fly"] and character and character:FindFirstChild("Humanoid") do
                local moveDir = character.Humanoid.MoveDirection
                bodyVelocity.Velocity = moveDir * 50
                task.wait()
            end
        end)
    else
        if bodyVelocity then
            bodyVelocity:Destroy()
            bodyVelocity = nil
        end
    end
end)

-- Invisible
CreateToggle("Invisible", function(state)
    if LocalPlayer.Character then
        local trans = state and 1 or 0
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" or v:IsA("Decal") then
                v.Transparency = trans
            end
        end
    end
end)
